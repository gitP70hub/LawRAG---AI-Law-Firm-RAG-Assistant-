# ─────────────────────────────────────────────────────────────────────────────
# LawRAG — .gitignore
# ─────────────────────────────────────────────────────────────────────────────

# ── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyc
*.pyo
*.pyd
*.so

# Virtual environments
.venv/
venv/
env/
ENV/
.env.bak

# Distribution / packaging
*.egg-info/
*.egg
dist/
build/
.eggs/
*.whl
MANIFEST

# MyPy / type checkers
.mypy_cache/
.dmypy.json
dmypy.json
.pytype/

# Pytest
.pytest_cache/
.coverage
htmlcov/

# ── Environment & Secrets — NEVER COMMIT API KEYS ────────────────────────────
.env
*.env
.env.local
.env.*.local
backend/.env
backend/.env.*

# ── Database files ────────────────────────────────────────────────────────────
*.db
*.sqlite3
*.sqlite
lexai_dev.db
lawrag_dev.db

# ── ChromaDB vector store & uploads ──────────────────────────────────────────
backend/chroma_store/
backend/uploads/
backend/data/
chroma_store/
uploads/

# ── Node / Frontend ───────────────────────────────────────────────────────────
frontend/node_modules/
frontend/dist/
frontend/build/
frontend/.vite/
node_modules/
dist/
build/

# NPM / Yarn
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
package-lock.json

# ── VS Code ───────────────────────────────────────────────────────────────────
.vscode/
*.code-workspace

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
logs/
*.log.*

# ── Helper / one-off scripts (not production code) ───────────────────────────
backend/check_db.py
backend/clean_docs.py
backend/check_syntax.py
backend/test_rag.py
backend/test_models.py

# ── Alembic generated versions (keep ini, ignore auto-gen if using SQLite) ───
# alembic/versions/*.py   # Uncomment if you don't want to track migrations

# ── Jupyter ───────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── Temp / scratch ────────────────────────────────────────────────────────────
*.tmp
*.bak
*.swp
*~
