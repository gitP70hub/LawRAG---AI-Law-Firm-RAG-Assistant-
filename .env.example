# ── Application ───────────────────────────────────────────────────────────────
APP_NAME="LexAI"
APP_ENV="development"            # development | staging | production
DEBUG=true
SECRET_KEY="CHANGE_ME_use_openssl_rand_hex_32"

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=lexai
POSTGRES_PASSWORD=lexai_secret
POSTGRES_DB=lexai_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Async DSN  (used by SQLAlchemy)
DATABASE_URL="postgresql+asyncpg://lexai:lexai_secret@localhost:5432/lexai_db"

# Sync DSN  (used by Alembic)
SYNC_DATABASE_URL="postgresql+psycopg2://lexai:lexai_secret@localhost:5432/lexai_db"

# ── HuggingFace ───────────────────────────────────────────────────────────────
HUGGINGFACE_API_TOKEN="hf_YOUR_TOKEN_HERE"

# Model identifiers
LLM_MODEL_ID="mistralai/Mistral-7B-Instruct-v0.2"
EMBEDDING_MODEL_ID="sentence-transformers/all-MiniLM-L6-v2"

# ── ChromaDB ──────────────────────────────────────────────────────────────────
CHROMA_PERSIST_DIR="./data/chroma_db"
CHROMA_COLLECTION_NAME="lexai_documents"

# ── File Storage ──────────────────────────────────────────────────────────────
UPLOAD_DIR="./data/raw_docs"
MAX_UPLOAD_SIZE_MB=50

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGINS="http://localhost:3000,http://localhost:5173"
